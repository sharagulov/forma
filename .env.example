# Canonical URL for metadata, sitemap, and same-origin checks on /api/contact
NEXT_PUBLIC_SITE_URL=https://your-domain.example

# Optional: Mapbox GL (client-only; restrict token by URL in Mapbox dashboard — SEC-001)
NEXT_PUBLIC_MAPBOX_TOKEN=

# Contact form (Resend) — required for POST /api/contact to send mail
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
CONTACT_EMAIL_TO=studio@example.com
